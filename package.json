{
  "name": "scratch-lowlevel",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "dev:desktop": "pnpm --dir apps/desktop tauri dev",
    "build:desktop": "pnpm --dir apps/desktop tauri build",
    "lint": "eslint \"apps/web/src/**/*.{ts,tsx}\" && pnpm --dir apps/web lint:styles",
    "format": "prettier --write \"{apps,docs,.github}/**/*.{ts,tsx,js,json,md,yml,yaml}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"{apps,docs,.github}/**/*.{ts,tsx,js,json,md,yml,yaml}\" \"*.{json,md}\"",
    "typecheck": "pnpm --dir apps/web exec tsc --noEmit",
    "test": "pnpm --dir apps/web test",
    "changelog": "git cliff -o CHANGELOG.md || echo \"git-cliff not installed\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ],
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
