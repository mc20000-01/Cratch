{
  "name": "@scratchlowlevel/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint:styles": "node ./scripts/check-style-tokens.mjs",
    "storybook": "storybook dev -p 6006 --ci",
    "build-storybook": "storybook build",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots"
  },
  "dependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.14",
    "@types/node": "^24.10.1",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@vitejs/plugin-react": "*",
    "storybook": "^8.6.14",
    "typescript": "*",
    "vite": "*",
    "vitest": "^4.1.7"
  }
}
